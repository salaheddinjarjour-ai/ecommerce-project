# ─── Gemini AI ───────────────────────────────────────────────────────────────
# Required for the AI chatbot assistant to function.
# Local dev: copy this file to .env.local and fill in your key.
# Cloudflare Pages: add via Dashboard → Project → Settings → Environment Variables
VITE_GEMINI_API_KEY="your_gemini_api_key_here"

# ─── App URL ──────────────────────────────────────────────────────────────────
# The canonical public URL of the deployed site.
# Cloudflare Pages sets this automatically; you only need it locally.
VITE_APP_URL="http://localhost:3000"
